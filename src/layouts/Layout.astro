---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de" class="loading">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/logo.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Ladebildschirm -->
    <div id="preloader">
      <div class="loader-content">
        <img src="/logo.ico" alt="Color Cloud" class="loader-logo" />
        <div class="loader-bar"></div>
      </div>
    </div>

    <!-- Der Container für den Licht-Schweif -->
    <div id="cursor-trail-container"></div>
    
    <!-- Hier wird der Inhalt der Seiten eingefügt -->
    <slot />

    <script is:inline>
      (function() {
        const init = () => {
          const preloader = document.getElementById('preloader');
          const container = document.getElementById('cursor-trail-container');
          
          // Absoluter Scroll-Lock und Position zurücksetzen
          window.scrollTo(0, 0);
          document.documentElement.style.overflow = 'hidden';
          document.body.style.overflow = 'hidden';

          // Ladebildschirm nach dem Laden ausblenden
          if (preloader) {
            setTimeout(() => {
              preloader.style.opacity = '0';
              setTimeout(() => {
                preloader.style.display = 'none';
                // Scrollen wieder erlauben
                document.documentElement.classList.remove('loading');
                document.documentElement.style.overflow = 'auto';
                document.body.style.overflow = 'auto';
                
                // Spur erst jetzt sichtbar machen
                isLoaded = true;
                if (container) container.style.opacity = '1';
              }, 500);
            }, 1000); 
          }

          if (!container) return;

          let isLoaded = false; // Flag: Ist der Loader weg?

          // Einstellungen laden
          const enabled = localStorage.getItem('trailEnabled') !== 'false';
          const color = localStorage.getItem('trailColor') || '#00ffff';
          const sizeMultiplier = parseInt(localStorage.getItem('trailSize') || '100') / 100;

          if (!enabled) {
            container.style.display = 'none';
          } else {
            // Farbe in RGBA umwandeln für den Glow (0.4 Opacity)
            const hexToRgb = (hex) => {
              const r = parseInt(hex.slice(1, 3), 16);
              const g = parseInt(hex.slice(3, 5), 16);
              const b = parseInt(hex.slice(5, 7), 16);
              return `${r}, ${g}, ${b}`;
            };
            document.documentElement.style.setProperty('--trail-color', `rgba(${hexToRgb(color)}, 0.4)`);
          }

          const dots = [];
          const numDots = 12;
          let mouseX = 0;
          let mouseY = 0;

          // Erstelle die Tropfen-Elemente
          for (let i = 0; i < numDots; i++) {
            const dotEl = document.createElement('div');
            dotEl.className = 'trail-dot';
            const size = (100 - (i * 7)) * sizeMultiplier;
            dotEl.style.width = size + 'px';
            dotEl.style.height = (size * 1.3) + 'px';
            dotEl.style.opacity = (1 - (i / numDots)).toString();
            container.appendChild(dotEl);
            dots.push({ el: dotEl, x: 0, y: 0, angle: 0 });
          }

          window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            // Initialisierung auf die erste Mausposition
            if (dots[0].x === 0 && dots[0].y === 0) {
              dots.forEach(d => { d.x = mouseX; d.y = mouseY; });
            }
          });

          function animate() {
            let targetX = mouseX;
            let targetY = mouseY;

            // Video-Bereiche finden
            const videoRects = Array.from(document.querySelectorAll('iframe, .video-container')).map(el => el.getBoundingClientRect());

            dots.forEach((dot, index) => {
              const dx = targetX - dot.x;
              const dy = targetY - dot.y;
              
              dot.x += dx * 0.15;
              dot.y += dy * 0.15;
              
              if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
                dot.angle = Math.atan2(dy, dx) * (180 / Math.PI) + 90;
              }

              // Prüfen, ob dieser Punkt gerade unter einem Video ist
              const isUnderVideo = videoRects.some(rect => 
                dot.x > rect.left && dot.x < rect.right && 
                dot.y > rect.top && dot.y < rect.bottom
              );

              dot.el.style.left = dot.x + 'px';
              dot.el.style.top = dot.y + 'px';
              dot.el.style.transform = `translate(-50%, -50%) rotate(${dot.angle}deg)`;
              
              // Sichtbarkeit: Wenn unter Video -> 0, sonst Standard-Opacity
              const baseOpacity = (1 - (index / numDots));
              dot.el.style.opacity = isUnderVideo ? '0' : baseOpacity.toString();
              
              targetX = dot.x;
              targetY = dot.y;
            });
            
            requestAnimationFrame(animate);
          }
          
          animate();

          document.addEventListener('mouseleave', () => { 
            if (isLoaded) container.style.opacity = '0'; 
          });
          document.addEventListener('mouseenter', () => { 
            if (isLoaded) container.style.opacity = '1'; 
          });
        };

        // Startet, sobald das DOM bereit ist
        if (document.readyState === 'complete') init();
        else window.addEventListener('load', init);
      })();
    </script>
  </body>
</html>

<style is:global>
  html.loading, 
  html.loading body {
    overflow: hidden !important;
    height: 100vh !important;
  }

  html {
    height: 100%;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100%; /* Fix: Ermöglicht das Scrollen bei langen Inhalten */
    background-color: #0f172a;
    color: #f8fafc;
    font-family: 'Inter', system-ui, sans-serif;
    cursor: auto;
    overflow-x: hidden;
    /* Verhindert das versehentliche Markieren von Text */
    user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
  }

  #preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #0f172a;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000; /* Ganz oben */
    transition: opacity 0.5s ease;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loader-logo {
    width: 120px; /* Von 80px auf 120px vergrößert */
    height: 120px;
    filter: drop-shadow(0 0 15px rgba(56, 189, 248, 0.6));
    animation: pulse-logo 2s infinite ease-in-out;
  }

  .loader-bar {
    width: 250px; /* Von 200px auf 250px vergrößert */
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }

  .loader-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, #38bdf8, #8b5cf6);
    animation: loading-bar 1.5s infinite ease-in-out;
  }

  @keyframes pulse-logo {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  @keyframes loading-bar {
    0% { left: -100%; }
    50% { left: 0; }
    100% { left: 100%; }
  }

  #cursor-trail-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000; /* Wieder OBEN, damit man ihn sieht (taucht beim Video trotzdem ab) */
    transition: opacity 0.3s ease;
    opacity: 0; /* Standardmäßig unsichtbar während des Ladens */
  }

  .trail-dot {
    position: fixed;
    /* CSS Variablen für dynamische Anpassung */
    background: radial-gradient(ellipse at 50% 30%, var(--trail-color, rgba(0, 255, 255, 0.4)) 0%, rgba(0, 255, 255, 0) 70%);
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    mix-blend-mode: screen;
    filter: blur(8px);
    will-change: left, top, transform;
  }

  /* Content-Layering */
  main, nav, section, div:not(#cursor-trail-container, .trail-dot) {
    position: relative;
    z-index: 10;
  }
  /* --- Verschönerte Scrollleiste --- */
  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: #0f172a;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #38bdf8, #8b5cf6);
    border-radius: 10px;
    border: 2px solid #0f172a;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(to bottom, #00ffff, #a855f7);
  }

  /* Für Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: #38bdf8 #0f172a;
  }
</style>

---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de" class="loading">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/logo.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Ladebildschirm -->
    <div id="preloader">
      <div class="loader-content">
        <img src="/logo.ico" alt="Color Cloud" class="loader-logo" />
        <div class="loader-bar"></div>
      </div>
    </div>

    <!-- Der Container für den Licht-Schweif -->
    <div id="cursor-trail-container"></div>
    
    <!-- Hier wird der Inhalt der Seiten eingefügt -->
    <slot />

    <script is:inline>
      (function() {
        const init = () => {
          const preloader = document.getElementById('preloader');
          const container = document.getElementById('cursor-trail-container');
          
          window.scrollTo(0, 0);
          document.documentElement.style.overflow = 'hidden';
          document.body.style.overflow = 'hidden';

          if (preloader) {
            setTimeout(() => {
              preloader.style.opacity = '0';
              setTimeout(() => {
                preloader.style.display = 'none';
                document.documentElement.classList.remove('loading');
                document.documentElement.style.overflow = 'auto';
                document.body.style.overflow = 'auto';
                
                isLoaded = true;
                if (container) container.style.opacity = '1';

                // Initialisiere Animationen
                initScrollAnimations();
                initTiltEffect();
                initWindowManager();
              }, 500);
            }, 1000); 
          }

          let maxZIndex = 2000;
          let activeWindow = null;
          let initialX, initialY;

          function initWindowManager() {
            const configMode = localStorage.getItem('configMode') === 'true';
            if (!configMode) return;

            // Master Mouse-Events (Nur einmal für das ganze Dokument)
            document.addEventListener('mousemove', (e) => {
              if (activeWindow) {
                e.preventDefault();
                activeWindow.hasMoved = true;
                const x = e.clientX - initialX;
                const y = e.clientY - initialY;
                activeWindow.el.style.transform = `translate3d(${x}px, ${y}px, 0)`;
                activeWindow.x = x;
                activeWindow.y = y;
              }
            });

            document.addEventListener('mouseup', () => {
              if (activeWindow) {
                activeWindow.el.classList.remove('dragging');
                activeWindow = null;
              }
            });

            window.addEventListener('keydown', (e) => {
              if (e.ctrlKey && e.shiftKey && (e.key === '+' || e.key === '*')) {
                localStorage.setItem('configMode', 'false');
                alert('Konfigurations-Modus deaktiviert.');
                window.location.reload();
              }
            });

            const cards = document.querySelectorAll('.settings-card, .team-card, .content-card');
            
            cards.forEach((card, index) => {
              card.classList.add('window-mode');
              
              const handle = document.createElement('div');
              handle.className = 'window-handle';
              handle.innerHTML = `
                <span>⠿ Fenster</span>
                <div class="window-controls">
                  <button class="win-btn min-btn" title="Minimieren">−</button>
                  <button class="win-btn close-btn" title="Schließen">×</button>
                </div>
              `;
              card.prepend(handle);

              const startX = 50 + (index * 40);
              const startY = 150 + (index * 30);
              const winState = {
                el: card,
                x: startX,
                y: startY,
                hasMoved: false
              };

              card.style.position = 'absolute';
              card.style.left = '0px';
              card.style.top = '0px';
              card.style.transform = `translate3d(${startX}px, ${startY}px, 0)`;
              card.style.width = '320px';
              card.style.zIndex = maxZIndex + index;
              card.setAttribute('draggable', 'false');

              handle.addEventListener('mousedown', (e) => {
                if (e.target.closest('.window-handle') && !e.target.closest('.window-controls')) {
                  maxZIndex++;
                  card.style.zIndex = maxZIndex;
                  activeWindow = winState;
                  initialX = e.clientX - winState.x;
                  initialY = e.clientY - winState.y;
                  card.classList.add('dragging');
                  e.stopPropagation();
                  e.preventDefault();
                }
              });

              card.addEventListener('click', (e) => {
                if (configMode && winState.hasMoved) {
                  e.preventDefault();
                  e.stopPropagation();
                  winState.hasMoved = false;
                }
              }, true);

              handle.querySelector('.close-btn').onclick = (e) => {
                e.stopPropagation();
                card.style.display = 'none';
              };

              handle.querySelector('.min-btn').onclick = (e) => {
                e.stopPropagation();
                card.classList.toggle('minimized');
              };

              card.style.resize = 'both';
              card.style.overflow = 'hidden';
            });
          }

          function initScrollAnimations() {
            const observerOptions = {
              threshold: 0.1,
              rootMargin: "0px 0px -50px 0px"
            };

            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('revealed');
                }
              });
            }, observerOptions);

            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
          }

          function initTiltEffect() {
            const configMode = localStorage.getItem('configMode') === 'true';
            if (configMode) return; // Deaktivieren, wenn Fenster-Modus an ist

            const cards = document.querySelectorAll('.tilt');
            cards.forEach(card => {
              card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = (y - centerY) / 10;
                const rotateY = (centerX - x) / 10;
                
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;
              });
              
              card.addEventListener('mouseleave', () => {
                card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)`;
              });
            });
          }

          if (!container) return;
          let isLoaded = false;

          const enabled = localStorage.getItem('trailEnabled') !== 'false';
          const color = localStorage.getItem('trailColor') || '#00ffff';
          const sizeMultiplier = parseInt(localStorage.getItem('trailSize') || '100') / 100;

          if (!enabled) {
            container.style.display = 'none';
          } else {
            const hexToRgb = (hex) => {
              const r = parseInt(hex.slice(1, 3), 16);
              const g = parseInt(hex.slice(3, 5), 16);
              const b = parseInt(hex.slice(5, 7), 16);
              return `${r}, ${g}, ${b}`;
            };
            document.documentElement.style.setProperty('--trail-color', `rgba(${hexToRgb(color)}, 0.4)`);
          }

          const dots = [];
          const numDots = 12;
          let mouseX = 0;
          let mouseY = 0;

          for (let i = 0; i < numDots; i++) {
            const dotEl = document.createElement('div');
            dotEl.className = 'trail-dot';
            const size = (100 - (i * 7)) * sizeMultiplier;
            dotEl.style.width = size + 'px';
            dotEl.style.height = (size * 1.3) + 'px';
            dotEl.style.opacity = (1 - (i / numDots)).toString();
            container.appendChild(dotEl);
            dots.push({ el: dotEl, x: 0, y: 0, angle: 0 });
          }

          window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            if (dots[0].x === 0 && dots[0].y === 0) {
              dots.forEach(d => { d.x = mouseX; d.y = mouseY; });
            }
          });

          function animate() {
            let targetX = mouseX;
            let targetY = mouseY;
            const videoRects = Array.from(document.querySelectorAll('iframe, .video-container')).map(el => el.getBoundingClientRect());

            dots.forEach((dot, index) => {
              const dx = targetX - dot.x;
              const dy = targetY - dot.y;
              dot.x += dx * 0.15;
              dot.y += dy * 0.15;
              if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
                dot.angle = Math.atan2(dy, dx) * (180 / Math.PI) + 90;
              }
              const isUnderVideo = videoRects.some(rect => 
                dot.x > rect.left && dot.x < rect.right && 
                dot.y > rect.top && dot.y < rect.bottom
              );
              dot.el.style.left = dot.x + 'px';
              dot.el.style.top = dot.y + 'px';
              dot.el.style.transform = `translate(-50%, -50%) rotate(${dot.angle}deg)`;
              const baseOpacity = (1 - (index / numDots));
              dot.el.style.opacity = isUnderVideo ? '0' : baseOpacity.toString();
              targetX = dot.x;
              targetY = dot.y;
            });
            requestAnimationFrame(animate);
          }
          animate();

          document.addEventListener('mouseleave', () => { if (isLoaded) container.style.opacity = '0'; });
          document.addEventListener('mouseenter', () => { if (isLoaded) container.style.opacity = '1'; });
        };

        if (document.readyState === 'complete') init();
        else window.addEventListener('load', init);
      })();
    </script>
  </body>
</html>

<style is:global>
  html.loading, 
  html.loading body {
    overflow: hidden !important;
    height: 100vh !important;
  }

  html {
    height: 100%;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    background-color: #0f172a;
    color: #f8fafc;
    font-family: 'Inter', system-ui, sans-serif;
    cursor: auto;
    overflow-x: hidden;
    user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
  }

  /* --- Advanced Animations --- */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Floating Effekt */
  .floating {
    animation: floating 3s ease-in-out infinite;
  }

  @keyframes floating {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  /* Glow Pulse */
  .glow-pulse {
    animation: glow-pulse 2s infinite ease-in-out;
  }

  @keyframes glow-pulse {
    0% { box-shadow: 0 0 5px rgba(56, 189, 248, 0.2); }
    50% { box-shadow: 0 0 20px rgba(56, 189, 248, 0.5); }
    100% { box-shadow: 0 0 5px rgba(56, 189, 248, 0.2); }
  }

  /* Glanz-Effekt für Karten */
  .shine-effect {
    position: relative;
    overflow: hidden;
  }

  .shine-effect::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(255, 255, 255, 0.05),
      transparent
    );
    transform: rotate(45deg);
    transition: all 0.5s;
    pointer-events: none;
  }

  .shine-effect:hover::after {
    left: 100%;
    top: 100%;
    transition: all 0.7s;
  }


  /* Verschiedene Reveal-Typen */
  .reveal-left { transform: translateX(-30px); }
  .reveal-right { transform: translateX(30px); }
  .reveal-scale { transform: scale(0.9); }
  
  .reveal.revealed.reveal-left,
  .reveal.revealed.reveal-right { transform: translateX(0); }
  .reveal.revealed.reveal-scale { transform: scale(1); }

  /* --- Desktop / Window Mode CSS --- */
  .window-mode {
    border: 1px solid rgba(56, 189, 248, 0.5) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6) !important;
    cursor: default !important;
    transition: none !important; /* Deaktiviert Hover-Animationen im Window-Modus für Performance */
  }

  .window-handle {
    background: linear-gradient(to right, #1e293b, #334155);
    padding: 8px 12px;
    border-top-left-radius: 15px;
    border-top-right-radius: 15px;
    margin: -1.5rem -1.5rem 1rem -1.5rem; /* Gleicht das Card-Padding aus */
    cursor: grab;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    user-select: none;
  }

  .window-handle:active {
    cursor: grabbing;
  }

  .window-handle span {
    font-size: 0.75rem;
    font-weight: 700;
    color: #38bdf8;
    text-transform: uppercase;
    letter-spacing: 1px;
    flex-grow: 1;
  }

  .window-controls {
    display: flex;
    gap: 8px;
  }

  .win-btn {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s;
  }

  .win-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .close-btn:hover {
    background: #ef4444 !important;
  }

  /* Minimiert Zustand */
  .window-mode.minimized {
    height: 40px !important;
    min-height: 40px !important;
    overflow: hidden !important;
    padding-bottom: 0 !important;
    resize: none !important;
  }

  /* Resize Handle Styling */
  .window-mode::-webkit-resizer {
    background-color: transparent;
    background-image: radial-gradient(circle at center, #38bdf8 1px, transparent 1px);
    background-size: 3px 3px;
  }


  #preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #0f172a;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000; /* Ganz oben */
    transition: opacity 0.5s ease;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loader-logo {
    width: 120px; /* Von 80px auf 120px vergrößert */
    height: 120px;
    filter: drop-shadow(0 0 15px rgba(56, 189, 248, 0.6));
    animation: pulse-logo 2s infinite ease-in-out;
  }

  .loader-bar {
    width: 250px; /* Von 200px auf 250px vergrößert */
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }

  .loader-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, #38bdf8, #8b5cf6);
    animation: loading-bar 1.5s infinite ease-in-out;
  }

  @keyframes pulse-logo {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  @keyframes loading-bar {
    0% { left: -100%; }
    50% { left: 0; }
    100% { left: 100%; }
  }

  #cursor-trail-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000; /* Wieder OBEN, damit man ihn sieht (taucht beim Video trotzdem ab) */
    transition: opacity 0.3s ease;
    opacity: 0; /* Standardmäßig unsichtbar während des Ladens */
  }

  .trail-dot {
    position: fixed;
    /* CSS Variablen für dynamische Anpassung */
    background: radial-gradient(ellipse at 50% 30%, var(--trail-color, rgba(0, 255, 255, 0.4)) 0%, rgba(0, 255, 255, 0) 70%);
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    mix-blend-mode: screen;
    filter: blur(8px);
    will-change: left, top, transform;
  }

  /* Content-Layering */
  main, nav, section, div:not(#cursor-trail-container, .trail-dot) {
    position: relative;
    z-index: 10;
  }
  /* --- Verschönerte Scrollleiste --- */
  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: #0f172a;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #38bdf8, #8b5cf6);
    border-radius: 10px;
    border: 2px solid #0f172a;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(to bottom, #00ffff, #a855f7);
  }

  /* Für Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: #38bdf8 #0f172a;
  }
</style>

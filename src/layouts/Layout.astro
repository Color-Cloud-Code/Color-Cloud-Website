---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de" class="loading">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/logo.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <!-- Ladebildschirm -->
    <div id="preloader">
      <div class="loader-content">
        <img src="/logo.ico" alt="Color Cloud" class="loader-logo" />
        <div class="loader-bar"></div>
      </div>
    </div>

    <!-- Der Container für den Licht-Schweif -->
    <div id="cursor-trail-container"></div>
    
    <!-- Hier wird der Inhalt der Seiten eingefügt -->
    <slot />

    <!-- Eigener Cursor -->
    <div id="custom-cursor"></div>

    <script is:inline>
      (function() {
        let isLoaded = false;
        let mouseX = 0;
        let mouseY = 0;
        let dots = [];
        let animationFrameId = null;
        let titleInterval = null;
        let originalTitle = document.title;

        const startTitleLoading = () => {
          if (titleInterval) clearInterval(titleInterval);
          originalTitle = document.title;
          let step = 0;
          const frames = ["-", "--", "---", "----", "-----", "------", "-------", "--------"];
          
          titleInterval = setInterval(() => {
            document.title = frames[step] + " Loading";
            step = (step + 1) % frames.length;
          }, 150);
        };

        const stopTitleLoading = () => {
          if (titleInterval) {
            clearInterval(titleInterval);
            titleInterval = null;
            document.title = originalTitle;
          }
        };

        const init = () => {
          stopTitleLoading();
          const preloader = document.getElementById('preloader');
          const container = document.getElementById('cursor-trail-container');
          const customCursor = document.getElementById('custom-cursor');
          
          // Animationen initialisieren
          initScrollAnimations();
          initTiltEffect();

          if (preloader && !isLoaded) {
            window.scrollTo(0, 0);
            document.documentElement.style.overflow = 'hidden';
            document.body.style.overflow = 'hidden';

            setTimeout(() => {
              preloader.style.opacity = '0';
              setTimeout(() => {
                preloader.style.display = 'none';
                document.documentElement.classList.remove('loading');
                document.documentElement.style.overflow = 'auto';
                document.body.style.overflow = 'auto';
                isLoaded = true;
                if (container) container.style.opacity = '1';
              }, 500);
            }, 1000); 
          } else if (preloader) {
            preloader.style.display = 'none';
            document.documentElement.classList.remove('loading');
            document.documentElement.style.overflow = 'auto';
            document.body.style.overflow = 'auto';
            if (container) container.style.opacity = '1';
          }
          
          // Cursor-Einstellungen laden
          const customCursorEnabled = localStorage.getItem('customCursorEnabled') === 'true';
          const cursorSize = parseInt(localStorage.getItem('cursorSize') || '32');
          
          if (customCursorEnabled && customCursor) {
            customCursor.style.display = 'block';
            customCursor.style.width = cursorSize + 'px';
            customCursor.style.height = cursorSize + 'px';
            document.body.style.cursor = 'none';
            const style = document.createElement('style');
            style.innerHTML = `* { cursor: none !important; }`;
            document.head.appendChild(style);
          } else {
            document.body.style.cursor = 'auto';
          }

          function initScrollAnimations() {
            const observerOptions = { threshold: 0.1, rootMargin: "0px 0px -50px 0px" };
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('revealed');
              });
            }, observerOptions);
            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
          }

          function initTiltEffect() {
            const cards = document.querySelectorAll('.tilt');
            cards.forEach(card => {
              card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                const rotateX = (y - centerY) / 10;
                const rotateY = (centerX - x) / 10;
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;
              });
              card.addEventListener('mouseleave', () => {
                card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)`;
              });
            });
          }

          // Trail initialisieren
          if (container) {
            container.innerHTML = '';
            dots = [];
            const enabled = localStorage.getItem('trailEnabled') !== 'false';
            const color = localStorage.getItem('trailColor') || '#00ffff';
            const sizeMultiplier = parseInt(localStorage.getItem('trailSize') || '100') / 100;

            if (!enabled) {
              container.style.display = 'none';
            } else {
              container.style.display = 'block';
              const hexToRgb = (hex) => {
                const r = parseInt(hex.slice(1, 3), 16);
                const g = parseInt(hex.slice(3, 5), 16);
                const b = parseInt(hex.slice(5, 7), 16);
                return `${r}, ${g}, ${b}`;
              };
              document.documentElement.style.setProperty('--trail-color', `rgba(${hexToRgb(color)}, 0.4)`);
              
              const numDots = 12;
              for (let i = 0; i < numDots; i++) {
                const dotEl = document.createElement('div');
                dotEl.className = 'trail-dot';
                const size = (100 - (i * 7)) * sizeMultiplier;
                dotEl.style.width = size + 'px';
                dotEl.style.height = (size * 1.3) + 'px';
                dotEl.style.opacity = (1 - (i / numDots)).toString();
                container.appendChild(dotEl);
                dots.push({ el: dotEl, x: mouseX, y: mouseY, angle: 0 });
              }
            }
          }

          if (animationFrameId) cancelAnimationFrame(animationFrameId);
          
          function animate() {
            let targetX = mouseX;
            let targetY = mouseY;
            const videoRects = Array.from(document.querySelectorAll('iframe, .video-container')).map(el => el.getBoundingClientRect());

            dots.forEach((dot, index) => {
              const dx = targetX - dot.x;
              const dy = targetY - dot.y;
              dot.x += dx * 0.15;
              dot.y += dy * 0.15;
              if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
                dot.angle = Math.atan2(dy, dx) * (180 / Math.PI) + 90;
              }
              const isUnderVideo = videoRects.some(rect => 
                dot.x > rect.left && dot.x < rect.right && 
                dot.y > rect.top && dot.y < rect.bottom
              );
              dot.el.style.left = dot.x + 'px';
              dot.el.style.top = dot.y + 'px';
              dot.el.style.transform = `translate(-50%, -50%) rotate(${dot.angle}deg)`;
              const baseOpacity = (1 - (index / 12));
              dot.el.style.opacity = isUnderVideo ? '0' : baseOpacity.toString();
              targetX = dot.x;
              targetY = dot.y;
            });
            animationFrameId = requestAnimationFrame(animate);
          }
          animate();
        };

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          const customCursor = document.getElementById('custom-cursor');
          if (customCursor && localStorage.getItem('customCursorEnabled') === 'true') {
            customCursor.style.left = mouseX + 'px';
            customCursor.style.top = mouseY + 'px';
          }
        });

        document.addEventListener('astro:before-preparation', startTitleLoading);
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>

<style is:global>
  html.loading, 
  html.loading body {
    overflow: hidden !important;
    height: 100vh !important;
  }

  html {
    height: 100%;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    background-color: #0f172a;
    color: #f8fafc;
    font-family: 'Inter', system-ui, sans-serif;
    cursor: auto;
    overflow-x: hidden;
    user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
  }

  /* --- Advanced Animations --- */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Floating Effekt */
  .floating {
    animation: floating 3s ease-in-out infinite;
  }

  @keyframes floating {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  /* Glow Pulse */
  .glow-pulse {
    animation: glow-pulse 2s infinite ease-in-out;
  }

  @keyframes glow-pulse {
    0% { box-shadow: 0 0 5px rgba(56, 189, 248, 0.2); }
    50% { box-shadow: 0 0 20px rgba(56, 189, 248, 0.5); }
    100% { box-shadow: 0 0 5px rgba(56, 189, 248, 0.2); }
  }

  /* Glanz-Effekt für Karten */
  .shine-effect {
    position: relative;
    overflow: hidden;
  }

  .shine-effect::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(255, 255, 255, 0.05),
      transparent
    );
    transform: rotate(45deg);
    transition: all 0.5s;
    pointer-events: none;
  }

  .shine-effect:hover::after {
    left: 100%;
    top: 100%;
    transition: all 0.7s;
  }

  /* Verschiedene Reveal-Typen */
  .reveal-left { transform: translateX(-30px); }
  .reveal-right { transform: translateX(30px); }
  .reveal-scale { transform: scale(0.9); }
  
  .reveal.revealed.reveal-left,
  .reveal.revealed.reveal-right { transform: translateX(0); }
  .reveal.revealed.reveal-scale { transform: scale(1); }

  /* --- Custom Cursor --- */
  #custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 32px;
    height: 32px;
    background-image: url('/assets/Standart_curser.cur');
    background-size: contain;
    background-repeat: no-repeat;
    pointer-events: none; /* Klicks gehen durch den Cursor hindurch */
    z-index: 999999; /* Über allem anderen */
    display: none; /* Standardmäßig aus */
    transform: translate(0, 0); /* Verhindert Zittern */
  }

  /* Staggered Entrance Delays */
  .delay-100 { transition-delay: 100ms; }
  .delay-200 { transition-delay: 200ms; }
  .delay-300 { transition-delay: 300ms; }
  .delay-400 { transition-delay: 400ms; }
  .delay-500 { transition-delay: 500ms; }

  /* Text Shimmer Animation */
  .text-shimmer {
    background: linear-gradient(
      to right,
      #38bdf8 20%,
      #8b5cf6 40%,
      #8b5cf6 60%,
      #38bdf8 80%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    to { background-position: 200% center; }
  }

  #preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #0f172a;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000; /* Ganz oben */
    transition: opacity 0.5s ease;
  }

  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loader-logo {
    width: 120px;
    height: 120px;
    filter: drop-shadow(0 0 15px rgba(56, 189, 248, 0.6));
    animation: pulse-logo 2s infinite ease-in-out;
  }

  .loader-bar {
    width: 250px;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }

  .loader-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, #38bdf8, #8b5cf6);
    animation: loading-bar 1.5s infinite ease-in-out;
  }

  @keyframes pulse-logo {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  @keyframes loading-bar {
    0% { left: -100%; }
    50% { left: 0; }
    100% { left: 100%; }
  }

  #cursor-trail-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  .trail-dot {
    position: fixed;
    background: radial-gradient(ellipse at 50% 30%, var(--trail-color, rgba(0, 255, 255, 0.4)) 0%, rgba(0, 255, 255, 0) 70%);
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    mix-blend-mode: screen;
    filter: blur(8px);
    will-change: left, top, transform;
  }

  main, nav, section, div:not(#cursor-trail-container, .trail-dot) {
    position: relative;
    z-index: 10;
  }

  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: #0f172a;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #38bdf8, #8b5cf6);
    border-radius: 10px;
    border: 2px solid #0f172a;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(to bottom, #00ffff, #a855f7);
  }

  * {
    scrollbar-width: thin;
    scrollbar-color: #38bdf8 #0f172a;
  }
</style>

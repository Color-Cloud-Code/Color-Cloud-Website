---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "Über uns - Color Cloud";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      max-width: 1000px;
      margin: 0 auto;
      padding: 4rem 2rem;
      color: #f8fafc;
    }

    .hero {
      text-align: center;
      margin-bottom: 5rem;
    }

    h1 {
      font-size: 3.5rem;
      background: linear-gradient(to right, #38bdf8, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1.5rem;
    }

    .hero p {
      font-size: 1.5rem;
      color: #94a3b8;
      max-width: 700px;
      margin: 0 auto;
    }

    .section-title {
      font-size: 2rem;
      color: #38bdf8;
      margin-bottom: 2rem;
      text-align: center;
    }

    /* Team Sektion */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 3rem;
      margin-bottom: 5rem;
    }

    .team-card {
      background: rgba(30, 41, 59, 0.5);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 2rem;
      text-align: center;
      transition: transform 0.3s ease;
    }

    .team-card:hover {
      transform: translateY(-10px);
      border-color: rgba(56, 189, 248, 0.5);
    }

    .avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin-bottom: 1.5rem;
      border: 4px solid #38bdf8;
      padding: 5px;
      object-fit: cover;
    }

    .team-card h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .team-card span {
      color: #8b5cf6;
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* Tech Stack */
    .tech-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 5rem;
    }

    .tech-badge {
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid rgba(139, 92, 246, 0.3);
      color: #a78bfa;
      padding: 0.5rem 1.5rem;
      border-radius: 99px;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s ease;
    }

    .tech-badge:hover {
      background: rgba(139, 92, 246, 0.3);
      transform: scale(1.1);
      box-shadow: 0 0 15px rgba(139, 92, 246, 0.4);
      cursor: pointer;
    }

    /* Tech Modal Styles */
    .tech-modal {
      display: none;
      position: fixed;
      z-index: 10001;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(15, 23, 42, 0.9);
      backdrop-filter: blur(8px);
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background: rgba(30, 41, 59, 0.95);
      padding: 2.5rem;
      border: 1px solid rgba(56, 189, 248, 0.3);
      border-radius: 24px;
      width: 90%;
      max-width: 500px;
      position: relative;
      text-align: center;
      box-shadow: 0 0 50px rgba(56, 189, 248, 0.2);
      animation: modal-fade 0.3s ease-out;
    }

    @keyframes modal-fade {
      from {
        transform: scale(0.8);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .close-modal {
      position: absolute;
      right: 20px;
      top: 15px;
      font-size: 28px;
      font-weight: bold;
      color: #94a3b8;
      cursor: pointer;
      transition: color 0.2s;
    }

    .close-modal:hover {
      color: #38bdf8;
    }

    #modal-title {
      font-size: 2rem;
      color: #38bdf8;
      margin-bottom: 1rem;
    }

    #modal-description {
      font-size: 1.1rem;
      color: #cbd5e1;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .usage-tag {
      display: inline-block;
      background: rgba(139, 92, 246, 0.2);
      color: #a78bfa;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
    }

    /* Stats Sektion */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      text-align: center;
    }

    .stat-item {
      padding: 2rem;
    }

    .stat-number {
      display: block;
      font-size: 3rem;
      font-weight: 800;
      color: #f8fafc;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      color: #94a3b8;
      font-weight: 500;
    }
  </style>

  <main>
    <section class="hero reveal">
      <h1>Unsere Mission</h1>
      <p class="reveal delay-200">
        Wir bringen Farbe in deinen Discord-Server. Color Cloud wurde
        erschaffen, um Communities mit innovativen Tools und modernem Design zu
        verbinden.
      </p>
    </section>

    <h2 class="section-title reveal">Das Team hinter der Cloud</h2>
    <div class="team-grid">
      <div class="team-card reveal reveal-scale delay-100 tilt shine-effect">
        <img src="/Lead_logo.png" alt="Founder" class="avatar" />
        <h3>Color Cloud</h3>
        <span>Founder & Lead Developer</span>
      </div>
      <div class="team-card reveal reveal-scale delay-200 tilt shine-effect">
        <img src="/logo.ico" alt="Design" class="avatar" />
        <h3>Unknown</h3>
        <span>UI/UX Designer</span>
      </div>
      <div class="team-card reveal reveal-scale delay-300 tilt shine-effect">
        <img src="/logo.ico" alt="Support" class="avatar" />
        <h3>Unknown</h3>
        <span>Community Manager</span>
      </div>
    </div>

    <h2 class="section-title reveal">Unser Tech Stack</h2>
    <div class="tech-grid" id="tech-grid">
      <div class="tech-badge reveal reveal-scale delay-100" data-tech="Astro">Astro</div>
      <div class="tech-badge reveal reveal-scale delay-200" data-tech="Python">Python</div>
      <div class="tech-badge reveal reveal-scale delay-300" data-tech="CSharp">C#</div>
      <div class="tech-badge reveal reveal-scale delay-400" data-tech="Cpp">C++</div>
      <div class="tech-badge reveal reveal-scale delay-500" data-tech="JavaScript">JavaScript</div>
      <div class="tech-badge reveal reveal-scale delay-100" data-tech="Java">Java</div>
      <div class="tech-badge reveal reveal-scale delay-200" data-tech="TypeScript">TypeScript</div>
      <div class="tech-badge reveal reveal-scale delay-300" data-tech="Markdown">Markdown</div>
      <div class="tech-badge reveal reveal-scale delay-400" data-tech="Database">Database</div>
      <div class="tech-badge reveal reveal-scale delay-500" data-tech="JSON">JSON</div>
      <div class="tech-badge reveal reveal-scale delay-100" data-tech="Golang">Golang</div>
      <div class="tech-badge reveal reveal-scale delay-200" data-tech="HTML">HTML</div>
      <div class="tech-badge reveal reveal-scale delay-300" data-tech="CSS">CSS</div>
      <div class="tech-badge reveal reveal-scale delay-400" data-tech="C">C</div>
    </div>

    <!-- Info Modal für Tech Stack -->
    <div id="tech-modal" class="tech-modal">
      <div class="modal-content">
        <span class="close-modal">&times;</span>
        <h3 id="modal-title">Technologie</h3>
        <p id="modal-description">Beschreibung folgt...</p>
        <div class="usage-tag">
          Verwendung: <span id="modal-usage">Bereich</span>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-item reveal delay-100">
        <span class="stat-number">150+</span>
        <span class="stat-label">Server</span>
      </div>
      <div class="stat-item reveal delay-300">
        <span class="stat-number">45k</span>
        <span class="stat-label">Nutzer</span>
      </div>
      <div class="stat-item reveal delay-500">
        <span class="stat-number">99.9%</span>
        <span class="stat-label">Uptime</span>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  // Tech Stack Modal Logik
  const techData = {
    Astro: {
      desc: "Ein modernes Framework für extrem schnelle Webseiten. Wir nutzen es für dieses Dashboard.",
      usage: "Frontend & Performance",
    },
    Python: {
      desc: "Eine extrem vielseitige Sprache, ideal für Backend-Logik und komplexe Bot-Features.",
      usage: "Bot-Entwicklung & KI",
    },
    CSharp: {
      desc: "Eine leistungsstarke, objektorientierte Sprache von Microsoft für robuste Anwendungen.",
      usage: "Backend & Windows Apps",
    },
    Cpp: {
      desc: "Hardwarenahe Hochleistungssprache für Anwendungen, bei denen jede Millisekunde zählt.",
      usage: "System-Programmierung",
    },
    JavaScript: {
      desc: "Die Sprache des Webs. Sie macht dieses Dashboard interaktiv (z.B. den Cursor-Trail).",
      usage: "Web-Interaktivität",
    },
    Java: {
      desc: "Eine universelle Sprache, bekannt für Stabilität und Plattformunabhängigkeit.",
      usage: "Enterprise & Backend",
    },
    TypeScript: {
      desc: "JavaScript mit Superkräften. Macht den Code durch Typen sicherer und wartbarer.",
      usage: "Große Web-Apps",
    },
    Markdown: {
      desc: "Eine einfache Auszeichnungssprache für formatierte Texte und Dokumentationen.",
      usage: "Dokumentation",
    },
    Database: {
      desc: "Der Speicherort für alle wichtigen Daten wie Server-Settings und User-Levels.",
      usage: "Datenverwaltung",
    },
    JSON: {
      desc: "Das Standardformat zum Austausch von Daten zwischen Server und Dashboard.",
      usage: "Datenaustausch",
    },
    Golang: {
      desc: "Eine moderne, extrem schnelle Sprache von Google für skalierbare Cloud-Systeme.",
      usage: "Hochleistungs-Backends",
    },
    HTML: {
      desc: "Das Grundgerüst jeder Webseite. Ohne HTML gäbe es keine Struktur im Internet.",
      usage: "Web-Struktur",
    },
    CSS: {
      desc: "Verantwortlich für das Styling. CSS macht dieses Dashboard so schick wie es ist.",
      usage: "Design & Layout",
    },
    C: {
      desc: "Die Mutter fast aller modernen Sprachen. Extrem schnell und hardwarenah.",
      usage: "System-Kernel & Treiber",
    },
  };

  const modal = document.getElementById("tech-modal");
  const closeBtn = document.querySelector(".close-modal");

  document.querySelectorAll(".tech-badge").forEach((badge) => {
    badge.addEventListener("click", () => {
      const tech = badge.getAttribute("data-tech");
      const data = techData[tech];

      document.getElementById("modal-title").innerText =
        tech === "CSharp" ? "C#" : tech === "Cpp" ? "C++" : tech;
      document.getElementById("modal-description").innerText = data.desc;
      document.getElementById("modal-usage").innerText = data.usage;

      modal.style.display = "flex";
      document.body.style.overflow = "hidden"; // Scrollen verhindern
    });
  });

  const closeModal = () => {
    modal.style.display = "none";
    document.body.style.overflow = "auto"; // Scrollen wieder erlauben
  };

  closeBtn.addEventListener("click", closeModal);
  window.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
</script>

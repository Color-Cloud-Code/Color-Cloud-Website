---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import fs from 'node:fs';
import path from 'node:path';

const pageTitle = "Top Videos of the Day - Color Cloud";

// Funktion zum sicheren Auslesen des Video-Links (ID oder ganzer Iframe)
function getVideoSrc(platz) {
  try {
    const filePath = path.join(process.cwd(), 'src', 'pages', 'content', 'Video-Of-the-Day', platz, 'video.txt');
    if (fs.existsSync(filePath)) {
      const content = fs.readFileSync(filePath, 'utf-8').trim();
      
      // 1. Suche nach dem src-Attribut, falls es ein Iframe-Code ist
      const iframeMatch = content.match(/src=["']([^"']+)["']/);
      if (iframeMatch) return iframeMatch[1];
      
      // 2. Suche nach einer YouTube ID im Text/Link
      const idMatch = content.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&]{11})/);
      if (idMatch) return `https://www.youtube.com/embed/${idMatch[1]}`;
      
      // 3. Falls es nur die ID ist
      if (content.length === 11) return `https://www.youtube.com/embed/${content}`;
      
      return content; // Fallback für den Fall, dass es schon ein sauberer Link ist
    }
  } catch (e) {
    console.error(`Fehler beim Lesen von ${platz}:`, e);
  }
  return "https://www.youtube.com/embed/b0hL4mJInm0"; // Fallback
}

const videos = [
  {
    rank: "Platz 1",
    src: getVideoSrc('platz_1'),
    title: "Der heutige Spitzenreiter",
    desc: "Gefällt dem Team am besten!",
    color: "#fbbf24"
  },
  {
    rank: "Platz 2",
    src: getVideoSrc('Platz_2'),
    title: "Starker Verfolger",
    desc: "Ein Muss für heute.",
    color: "#94a3b8"
  },
  {
    rank: "Platz 3",
    src: getVideoSrc('Platz_3'),
    title: "Ehrenplatz",
    desc: "Immer noch fantastisch.",
    color: "#a78bfa"
  }
];
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 4rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      text-align: center;
      margin-bottom: 4rem;
    }

    h1 {
      font-size: 3.5rem;
      margin-bottom: 1rem;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 2rem;
      color: #38bdf8;
      text-decoration: none;
      font-weight: 500;
    }

    .video-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .video-card.rank-1 {
      grid-column: 1 / -1;
      margin-bottom: 2rem;
    }

    .video-card {
      background: rgba(30, 41, 59, 0.4);
      backdrop-filter: blur(12px);
      border-radius: 24px;
      padding: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.4s ease;
    }

    .video-card:hover {
      transform: translateY(-5px);
      border-color: var(--rank-color);
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .rank-badge {
      display: inline-block;
      padding: 0.4rem 1rem;
      border-radius: 100px;
      background: var(--rank-color);
      color: #0f172a;
      font-weight: 800;
      font-size: 0.9rem;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .video-container {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 1.5rem;
      background: #000;
    }

    iframe {
      width: 100%;
      height: 100%;
      border: none;
    }

    .info h2 {
      margin: 0 0 0.5rem 0;
      color: white;
    }

    .info p {
      color: #94a3b8;
      margin: 0;
    }

    @media (max-width: 768px) {
      .video-grid {
        grid-template-columns: 1fr;
      }
      h1 { font-size: 2.5rem; }
    }
  </style>

  <main>
    <a href="/content" class="back-link reveal reveal-left">← Zurück zum Content Hub</a>
    
    <div class="header reveal">
      <h1 class="text-shimmer">Videos of the Day</h1>
      <p>Die Top 3 Favoriten - Gelesen aus deinen Dateien</p>
    </div>

    <div class="video-grid">
      {videos.map((vid, index) => (
        <div 
          class={`video-card rank-${index + 1} reveal reveal-scale delay-${(index + 1) * 200}`}
          style={`--rank-color: ${vid.color}`}
        >
          <span class="rank-badge">{vid.rank}</span>
          <div class="video-container">
            <iframe
              src={vid.src}
              title={vid.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
          <div class="info">
            <h2>{vid.title}</h2>
            <p>{vid.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

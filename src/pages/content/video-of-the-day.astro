---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

const pageTitle = "Video of the Day - Color Cloud";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 4rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .back-link {
      align-self: flex-start;
      max-width: 900px;
      margin: 0 auto 1rem auto;
      width: 100%;
      color: #38bdf8;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
      transition: opacity 0.2s ease;
    }

    .back-link:hover {
      opacity: 0.8;
    }

    h1 {
      font-size: 2.5rem;
      background: linear-gradient(to right, #38bdf8, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin: 0;
    }

    .video-container {
      width: 100%;
      max-width: 900px;
      aspect-ratio: 16 / 9;
      box-shadow: 0 0 30px rgba(56, 189, 248, 0.2);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(56, 189, 248, 0.3);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .video-container:hover {
      box-shadow: 0 0 50px rgba(56, 189, 248, 0.5);
      border-color: rgba(56, 189, 248, 0.6);
      transform: translateY(-10px) scale(1.02);
    }

    iframe {
      width: 100%;
      height: 100%;
    }

    p {
      color: #94a3b8;
      text-align: center;
    }
  </style>

  <main>
    <a href="/content" class="back-link">← Zurück zum Content Hub</a>
    <h1>Video of the Day</h1>
    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/8JtuB0inun0"
        title="Video of the Day"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
    <p>Video of the Day gewählt von den Mitarbeitern von Color Cloud</p>
  </main>
</Layout>

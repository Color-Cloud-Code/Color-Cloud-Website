---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

const pageTitle = "Top Music of the Day - Color Cloud";

// Wir nutzen Astro's "Glob", um alle music.txt Dateien beim Build-Prozess einzusammeln
// Das funktioniert auf jedem Server (Cloudflare, GitHub, etc.)
const allMusicFiles = import.meta.glob('./Music-Of-The-Day/**/music.txt', { query: '?raw', eager: true });

function getMusicData(platz: string) {
  try {
    // Wir suchen in den geladenen Dateien nach dem richtigen Pfad (ignoriert Groß/Kleinschreibung)
    const fileKey = Object.keys(allMusicFiles).find(key => 
      key.toLowerCase().includes(platz.toLowerCase())
    );

    if (fileKey) {
      const rawContent = allMusicFiles[fileKey].default;
      const lines = rawContent.split(/\r?\n/).map((l: string) => l.trim()).filter((l: string) => l !== "");
      const firstLine = lines[0] || "";
      const isNSTH = lines.some((l: string) => l.toUpperCase() === "NSTH");
      
      let src = "";
      const iframeMatch = firstLine.match(/src=["']([^"']+)["']/);
      if (iframeMatch) {
        src = iframeMatch[1];
      } else {
        const idMatch = firstLine.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&]{11})/);
        src = idMatch ? `https://www.youtube.com/embed/${idMatch[1]}` : (firstLine.length === 11 ? `https://www.youtube.com/embed/${firstLine}` : firstLine);
      }
      return { src, isNSTH, error: false };
    }
  } catch (e) {
    console.error(`Fehler bei ${platz}:`, e);
  }
  return { src: "https://www.youtube.com/embed/cHHLHGNpCSA", isNSTH: false, error: true };
}

const songs = [
  { rank: "Platz 1", data: getMusicData('platz_1'), title: "Der Hit des Tages", desc: "Maximale Vibes für heute!", color: "#fbbf24" },
  { rank: "Platz 2", data: getMusicData('Platz_2'), title: "Chilliger Vibe", desc: "Perfekt zum Arbeiten oder Entspannen.", color: "#94a3b8" },
  { rank: "Platz 3", data: getMusicData('Platz_3'), title: "Oldie but Goldie", desc: "Ein Klassiker, der nie alt wird.", color: "#a78bfa" }
];
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main { padding: 4rem 2rem; max-width: 1200px; margin: 0 auto; }
    .header { text-align: center; margin-bottom: 4rem; }
    h1 { font-size: 3.5rem; margin-bottom: 1rem; }
    .back-link { display: inline-block; margin-bottom: 2rem; color: #38bdf8; text-decoration: none; font-weight: 500; }
    .music-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .music-card.rank-1 { grid-column: 1 / -1; margin-bottom: 2rem; }
    .music-card {
      background: rgba(30, 41, 59, 0.4);
      backdrop-filter: blur(12px);
      border-radius: 24px;
      padding: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.4s ease;
      position: relative;
    }
    .music-card:hover { transform: translateY(-5px); border-color: var(--rank-color); }
    .rank-badge {
      display: inline-block; padding: 0.4rem 1rem; border-radius: 100px; background: var(--rank-color);
      color: #0f172a; font-weight: 800; font-size: 0.9rem; margin-bottom: 1rem; text-transform: uppercase;
    }
    .music-container { width: 100%; aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem; background: #000; position: relative; }
    iframe { width: 100%; height: 100%; border: none; }
    .nsth-overlay {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(25px);
      display: flex; flex-direction: column; justify-content: center; align-items: center;
      z-index: 10; transition: all 0.5s ease; padding: 2rem; text-align: center;
    }
    .nsth-overlay.hidden { opacity: 0; pointer-events: none; }
    .nsth-warning { color: #ef4444; font-weight: 800; font-size: 1.5rem; margin-bottom: 1rem; }
    .nsth-btn { background: #ef4444; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 12px; font-weight: 700; cursor: pointer; }
    .info h2 { color: white; margin: 0 0 0.5rem 0; }
    .info p { color: #94a3b8; margin: 0; }
    @media (max-width: 768px) { .music-grid { grid-template-columns: 1fr; } }
  </style>

  <main>
    <a href="/content" class="back-link reveal reveal-left">← Zurück zum Content Hub</a>
    <div class="header reveal">
      <h1 class="text-shimmer">Music of the Day</h1>
      <p>Kuratierte Tracks von Color Cloud</p>
    </div>

    <div class="music-grid">
      {songs.map((song, index) => (
        <div 
          class={`music-card rank-${index + 1} reveal reveal-scale delay-${(index + 1) * 200}`}
          style={`--rank-color: ${song.color}`}
        >
          <span class="rank-badge">{song.rank}</span>
          
          <div class="music-container">
            {song.data.isNSTH && (
              <div class="nsth-overlay" id={`overlay-${index}`}>
                <div class="nsth-warning">⚠️ NSTH WARNUNG</div>
                <p style="color: white; margin-bottom: 1.5rem;">Dieser Inhalt könnte ungeeignet sein.</p>
                <button class="nsth-btn" onclick={`document.getElementById('overlay-${index}').classList.add('hidden')`}>
                  Inhalt anzeigen
                </button>
              </div>
            )}
            <iframe
              src={song.data.src}
              title={song.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>

          <div class="info">
            <h2>{song.title}</h2>
            <p>{song.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

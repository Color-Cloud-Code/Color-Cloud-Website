---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "Unsere Projekte - Color Cloud";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 6rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      text-align: center;
      margin-bottom: 4rem;
    }

    h1 {
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 1rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
    }

    .project-card {
      background: rgba(30, 41, 59, 0.5);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 2rem;
      transition: all 0.3s ease;
    }

    .project-card:hover {
      transform: translateY(-10px);
      border-color: #38bdf8;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .tag {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      background: rgba(56, 189, 248, 0.1);
      color: #38bdf8;
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    h2 {
      color: white;
      margin-bottom: 1rem;
    }

    p {
      color: #94a3b8;
      line-height: 1.6;
    }
  </style>

  <main>
    <div class="header reveal">
      <h1 class="text-shimmer">Geheime Projekte</h1>
      <p>Willkommen im versteckten Bereich der Color Cloud.</p>
    </div>

    <div class="projects-grid">
      <div class="project-card reveal reveal-scale delay-100 tilt">
        <span class="tag">Discord Bot</span>
        <h2>Color Cloud Bot</h2>
        <p>Unser Hauptprojekt: Ein multifunktionaler Discord Bot für Leveling, Moderation und Musik.</p>
      </div>

      <div class="project-card reveal reveal-scale delay-200 tilt">
        <span class="tag">Web App</span>
        <h2>Dashboard v2</h2>
        <p>Das brandneue Dashboard, an dem wir gerade arbeiten, um die Bot-Verwaltung noch einfacher zu machen.</p>
      </div>

      <div class="project-card reveal reveal-scale delay-300 tilt">
        <span class="tag">Python</span>
        <h2>AI Integration</h2>
        <p>Experimentelle Integration von KI-Modellen für intelligentere Auto-Moderation.</p>
      </div>
    </div>
  </main>
</Layout>

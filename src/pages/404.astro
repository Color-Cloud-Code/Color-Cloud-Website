---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "404 - Seite nicht gefunden";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 70vh;
      text-align: center;
      padding: 2rem;
    }

    .error-code {
      font-size: 8rem;
      font-weight: 900;
      background: linear-gradient(to right, #ef4444, #f87171);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin: 0;
      line-height: 1;
      filter: drop-shadow(0 0 20px rgba(239, 68, 68, 0.3));
    }

    h1 {
      font-size: 2rem;
      color: #f8fafc;
      margin-top: 1rem;
    }

    p {
      font-size: 1.25rem;
      color: #94a3b8;
      max-width: 500px;
      margin-bottom: 2rem;
    }

    .home-btn {
      background: linear-gradient(135deg, #38bdf8, #8b5cf6);
      color: white;
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: 12px;
      font-weight: 700;
      transition: all 0.3s ease;
      box-shadow: 0 10px 25px rgba(56, 189, 248, 0.3);
    }

    .home-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(56, 189, 248, 0.5);
    }
  </style>

  <main>
    <div class="error-code">404</div>
    <h1>FEHLER! Da ist nichts</h1>
    <p>Tut uns Leid, bitte probiere es später nochmals oder kehre zur Startseite zurück.</p>
    
    <a href="/" class="home-btn">Zurück zur Startseite</a>
  </main>
</Layout>

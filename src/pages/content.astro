---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "Content Hub - Color Cloud";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 4rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3rem;
    }

    .header {
      text-align: center;
    }

    h1 {
      font-size: 3.5rem;
      background: linear-gradient(to right, #38bdf8, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1rem;
    }

    .subtitle {
      color: #94a3b8;
      font-size: 1.2rem;
    }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      width: 100%;
    }

    .content-card {
      background: rgba(30, 41, 59, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 2rem;
      text-decoration: none;
      color: white;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
      overflow: hidden;
      backdrop-filter: blur(10px);
    }

    .content-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.1), rgba(139, 92, 246, 0.1));
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .content-card:hover {
      transform: translateY(-10px) scale(1.02);
      border-color: rgba(56, 189, 248, 0.5);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(56, 189, 248, 0.2);
    }

    .content-card:hover::before {
      opacity: 1;
    }

    .icon-box {
      width: 60px;
      height: 60px;
      background: rgba(56, 189, 248, 0.1);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: #38bdf8;
      margin-bottom: 0.5rem;
    }

    .content-card h2 {
      font-size: 1.5rem;
      margin: 0;
      color: #f8fafc;
    }

    .content-card p {
      color: #94a3b8;
      line-height: 1.6;
      margin: 0;
    }

    .card-footer {
      margin-top: auto;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #38bdf8;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .arrow {
      transition: transform 0.3s ease;
    }

    .content-card:hover .arrow {
      transform: translateX(5px);
    }
  </style>

  <main>
    <div class="header reveal">
      <h1>Content Hub</h1>
      <p class="subtitle reveal delay-200">Entdecke die täglichen Highlights der Color Cloud Community</p>
    </div>

    <div class="content-grid">
      <a href="/content/video-of-the-day" class="content-card reveal reveal-scale delay-100">
        <div class="icon-box">🎬</div>
        <h2>Video of the Day</h2>
        <p>Die coolsten Clips, handverlesen von unserem Team für dich.</p>
        <div class="card-footer">
          Ansehen <span class="arrow">→</span>
        </div>
      </a>

      <a href="/content/music-of-the-day" class="content-card reveal reveal-scale delay-300">
        <div class="icon-box">🎵</div>
        <h2>Music of the Day</h2>
        <p>Der perfekte Soundtrack für deinen Tag. Jeden Tag neu.</p>
        <div class="card-footer">
          Anhören <span class="arrow">→</span>
        </div>
      </a>

      <a href="/content/color-cloud-video" class="content-card reveal reveal-scale delay-500">
        <div class="icon-box">☁️</div>
        <h2>Color Cloud Video</h2>
        <p>Exklusive Videos rund um Color Cloud und unsere Projekte.</p>
        <div class="card-footer">
          Ansehen <span class="arrow">→</span>
        </div>
      </a>
    </div>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "Video of the Day - Color Cloud";
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 4rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    h1 {
      font-size: 2.5rem;
      background: linear-gradient(to right, #38bdf8, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin: 0;
    }

    .video-container {
      width: 100%;
      max-width: 900px;
      aspect-ratio: 16 / 9;
      /* Dezent leuchtender Schatten */
      box-shadow: 0 0 30px rgba(56, 189, 248, 0.2);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(56, 189, 248, 0.3);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .video-container:hover {
      /* Stärkerer Glow und leichtes Anheben beim Hover */
      box-shadow: 0 0 50px rgba(56, 189, 248, 0.5);
      border-color: rgba(56, 189, 248, 0.6);
      transform: translateY(-10px) scale(1.02);
    }

    iframe {
      width: 100%;
      height: 100%;
    }
  </style>

  <main>
    <h1>Video of the Day</h1>
    <div class="video-container">
      <iframe
        width="815"
        height="458"
        src="https://www.youtube.com/embed/8JtuB0inun0"
        title="ich ZWINGE ihn sich zu entscheiden| Animierter Podcast  @Senpai Luca"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen></iframe>
    </div>
    <p>Video of the Day gewählt von den Mitarbeitern von Color Cloud</p>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const contentDir = path.join(__dirname, 'content');

function scanDir(dir) {
  if (!fs.existsSync(dir)) return { error: "Pfad existiert nicht: " + dir };
  const items = fs.readdirSync(dir);
  return items.map(item => {
    const fullPath = path.join(dir, item);
    const isDir = fs.statSync(fullPath).isDirectory();
    return {
      name: item,
      isDir,
      children: isDir ? scanDir(fullPath) : null
    };
  });
}

const structure = scanDir(contentDir);
---

<Layout title="Pfad Diagnose">
  <main style="padding: 4rem; color: white; font-family: monospace;">
    <h1>Ordner-Struktur Diagnose</h1>
    <p>Aktueller __dirname: {__dirname}</p>
    <hr />
    <pre>{JSON.stringify(structure, null, 2)}</pre>
  </main>
</Layout>

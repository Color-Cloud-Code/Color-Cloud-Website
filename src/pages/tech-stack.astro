---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const pageTitle = "Tech Stack - Color Cloud Bot";

const techs = [
  {
    name: "Database",
    icon: "🗄️",
    desc: "Sichere Datenspeicherung für Level und User-Profile.",
  },
  {
    name: "TypeScript",
    icon: "📘",
    desc: "Typensicheres JavaScript für stabilen Bot-Code.",
    status: "dev",
  },
  { name: "Python", icon: "🐍", desc: "KI-Module und komplexe Algorithmen." },
  {
    name: "JavaScript",
    icon: "💛",
    desc: "Die Basis für unser Web-Dashboard.",
  },
  {
    name: "Java",
    icon: "☕",
    desc: "Backend-Strukturen und High-Performance Module.",
    status: "dev",
  },
  {
    name: "C#",
    icon: "💜",
    desc: "Zusätzliche Tools und Systemintegrationen.",
    status: "dev",
  },
  {
    name: "C++",
    icon: "🚀",
    desc: "Maximale Performance (In Entwicklung).",
    status: "dev",
  },
  { name: "JSON", icon: "📄", desc: "Strukturierte Konfigurationsdateien." },
  {
    name: "Golang",
    icon: "🐹",
    desc: "Schnelle Microservices und Schnittstellen.",
  },
  {
    name: ".env",
    icon: "🔑",
    desc: "Sichere Verwaltung von API-Keys und Tokens.",
  },
];
---

<Layout title={pageTitle}>
  <Navbar />

  <style>
    main {
      padding: 6rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      text-align: center;
      margin-bottom: 5rem;
    }

    .back-btn {
      display: inline-block;
      margin-bottom: 2rem;
      color: #38bdf8;
      text-decoration: none;
      font-weight: 600;
    }

    .tech-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .tech-card {
      background: rgba(30, 41, 59, 0.4);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 20px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .tech-card:hover {
      background: rgba(56, 189, 248, 0.1);
      border-color: #38bdf8;
      transform: translateY(-5px) scale(1.02);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .tech-icon {
      font-size: 2.5rem;
    }

    .tech-name {
      font-size: 1.25rem;
      font-weight: 800;
      color: white;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .status-badge {
      font-size: 0.6rem;
      padding: 0.2rem 0.5rem;
      background: #f59e0b;
      color: black;
      border-radius: 4px;
      text-transform: uppercase;
    }

    .tech-desc {
      color: #94a3b8;
      font-size: 0.9rem;
      line-height: 1.5;
    }
  </style>

  <main>
    <a href="/projekte" class="back-btn reveal reveal-left"
      >← Zurück zu Projekten</a
    >

    <div class="header reveal">
      <h1 class="text-shimmer">Unser Tech Stack</h1>
      <p>Die Technologien, die den Color Cloud Bot antreiben.</p>
    </div>

    <div class="tech-grid">
      {
        techs.map((tech, index) => (
          <div
            class={`tech-card reveal reveal-scale tilt delay-${((index % 5) + 1) * 100}`}
          >
            <div class="tech-icon">{tech.icon}</div>
            <div class="tech-name">
              {tech.name}
              {tech.status === "dev" && (
                <span class="status-badge">In Arbeit</span>
              )}
            </div>
            <p class="tech-desc">{tech.desc}</p>
          </div>
        ))
      }
    </div>
  </main>
</Layout>

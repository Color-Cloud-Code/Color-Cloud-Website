---
import Layout from "../../../../../layouts/Layout.astro";
import Navbar from "../../../../../components/Navbar.astro";

const pageTitle = "System Error? - April Easter Egg";
---

<Layout title={pageTitle}>
  <div class="os-container">
    <div class="desktop">
      <!-- Desktop Icons -->
      <div class="desktop-icon" id="my-pc">
        <div class="icon-img">🖥️</div>
        <span>Dieser PC</span>
      </div>
      <div class="desktop-icon" id="trash">
        <div class="icon-img">🗑️</div>
        <span>Papierkorb</span>
      </div>

      <!-- Das Fenster -->
      <div class="window" id="easter-window">
        <div class="window-header" id="window-handle">
          <div class="window-title">
            <span class="icon">📁</span>
            Geheime Daten - April 2026
          </div>
          <div class="window-controls">
            <button class="minimize">_</button>
            <button class="maximize">□</button>
            <button class="close">×</button>
          </div>
        </div>
        <div class="window-content">
          <div class="error-msg">
            <span class="error-icon">⚠️</span>
            <h3>Zugriff gewährt!</h3>
            <p>Du hast den geheimen System-Code eingegeben.</p>
            <hr />
            <p><strong>Status:</strong> Administrator<br />
            <strong>Standort:</strong> Cloud-Server-04-2026</p>
          </div>
          <div class="file-list">
            <div class="file-item">📄 bot_config.env</div>
            <div class="file-item">📄 database_leak.json</div>
            <div class="file-item">📁 Python_Core</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .os-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: #008080; /* Klassisches Windows-Grün */
      background-image: url('https://images.unsplash.com/photo-1542831371-29b0f74f9713?auto=format&fit=crop&q=80&w=2070');
      background-size: cover;
      z-index: 50;
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .desktop {
      position: relative;
      width: 100%;
      height: 100%;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .desktop-icon {
      width: 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      color: white;
      text-shadow: 1px 1px 2px black;
      cursor: pointer;
      padding: 5px;
      border: 1px solid transparent;
    }

    .desktop-icon:hover {
      background: rgba(255, 255, 255, 0.2);
      border-color: rgba(255, 255, 255, 0.4);
    }

    .icon-img {
      font-size: 2.5rem;
      margin-bottom: 5px;
    }

    .desktop-icon span {
      font-size: 0.8rem;
      text-align: center;
    }

    /* Windows Style */
    .window {
      position: absolute;
      top: 150px;
      left: 300px;
      width: 500px;
      background: #f0f0f0;
      border: 2px solid #000;
      box-shadow: 4px 4px 0 #808080, inset 1px 1px 0 #fff;
      display: flex;
      flex-direction: column;
      z-index: 100;
      min-width: 300px;
    }

    .window-header {
      background: linear-gradient(to right, #000080, #1084d0);
      padding: 3px 6px;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: grab;
      user-select: none;
    }

    .window-header:active {
      cursor: grabbing;
    }

    .window-title {
      font-size: 0.9rem;
      font-weight: bold;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .window-controls {
      display: flex;
      gap: 2px;
    }

    .window-controls button {
      width: 20px;
      height: 18px;
      background: #c0c0c0;
      border: 1px solid #000;
      box-shadow: inset 1px 1px 0 #fff, 1px 1px 0 #808080;
      font-size: 10px;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 0;
    }

    .window-controls button:active {
      box-shadow: inset 1px 1px 0 #808080, 1px 1px 0 #fff;
      padding: 1px 0 0 1px;
    }

    .window-controls button.close {
      margin-left: 2px;
    }

    .window-content {
      padding: 20px;
      background: white;
      color: black;
      flex-grow: 1;
      border-top: 1px solid #808080;
    }

    .error-msg {
      margin-bottom: 20px;
    }

    .error-icon {
      font-size: 2rem;
      float: left;
      margin-right: 15px;
    }

    .file-list {
      background: #fff;
      border: 1px inset #808080;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .file-item {
      padding: 2px 5px;
      cursor: pointer;
    }

    .file-item:hover {
      background: #000080;
      color: white;
    }

    /* Animation */
    .window.minimized {
      display: none;
    }
  </style>

  <script>
    const initWindow = () => {
      const windowEl = document.getElementById('easter-window');
      const handle = document.getElementById('window-handle');
      const closeBtn = document.querySelector('.close');
      const minBtn = document.querySelector('.minimize');

      if (!windowEl || !handle) return;

      let isDragging = false;
      let offsetX, offsetY;

      handle.addEventListener('mousedown', (e) => {
        isDragging = true;
        offsetX = e.clientX - windowEl.offsetLeft;
        offsetY = e.clientY - windowEl.offsetTop;
        windowEl.style.zIndex = '1000';
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        windowEl.style.left = (e.clientX - offsetX) + 'px';
        windowEl.style.top = (e.clientY - offsetY) + 'px';
      });

      window.addEventListener('mouseup', () => {
        isDragging = false;
      });

      closeBtn.addEventListener('click', () => {
        window.location.href = '/';
      });

      minBtn.addEventListener('click', () => {
        windowEl.classList.toggle('minimized');
      });

      // Icons Interaktion
      document.getElementById('my-pc').addEventListener('dblclick', () => {
        windowEl.classList.remove('minimized');
      });
    };

    document.addEventListener('astro:page-load', initWindow);
  </script>
</Layout>
